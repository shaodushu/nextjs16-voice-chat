{
  "name": "nextjs16-voice-chat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"next dev --hostname 0.0.0.0 --experimental-https --experimental-https-key certificates/localhost-key.pem --experimental-https-cert certificates/localhost.pem\" \"tsx watch server/ws-server.ts\" \"python3 server/asr-cloud-server.py\" \"python3 server/tts-cloud-server.py\"",
    "dev:next": "next dev --hostname 0.0.0.0 --experimental-https --experimental-https-key certificates/localhost-key.pem --experimental-https-cert certificates/localhost.pem",
    "dev:ws": "tsx watch server/ws-server.ts",
    "dev:asr": "python3 server/asr-cloud-server.py",
    "dev:tts": "python3 server/tts-cloud-server.py",
    "dev:asr:local": "python3 server/asr-server.py",
    "dev:tts:local": "python3 server/tts-server.py",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/react": "^3.0.192",
    "@discordjs/opus": "^0.10.0",
    "@xenova/transformers": "^2.17.2",
    "ai": "^6.0.190",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "onnxruntime-web": "^1.26.0",
    "opus-recorder": "^8.0.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "ws": "^8.20.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs",
      "@discordjs/opus"
    ]
  }
}